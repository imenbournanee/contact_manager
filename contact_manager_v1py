import json
import os
import tkinter as tk
from tkinter import messagebox

FILE = "contacts.json"

# Contact Class
class Contact:
    def init(self, name, phone, email):
        self.name = name
        self.phone = phone
        self.email = email

    def to_dict(self):
        return {
            "name": self.name,
            "phone": self.phone,
            "email": self.email
        }

class ContactManager:
    def init(self):
        self.contacts = self.load()

    def load(self):
        if os.path.exists(FILE):
            with open(FILE) as f:
                data = json.load(f)
                return [Contact(**c) for c in data]
        return []

    def save(self):
        with open(FILE, "w") as f:
            json.dump([c.to_dict() for c in self.contacts], f, indent=2)
